{% extends '@UbermudaAdmin/base.html.twig' %}

{% block title %}Feature Flags Scan — Admin{% endblock %}

{% block body %}
    <div class="admin-page">
        <div class="flex items-start justify-between">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">Feature Flags Scan</h1>
                <p class="text-slate-500 text-sm mt-0.5">Checks code references against the database.</p>
            </div>
            <a href="{{ path('ubermuda_feature_flags_list') }}" class="admin-button-secondary admin-button-small shrink-0">Back to flags</a>
        </div>

        <div class="flex flex-col gap-3">
            <div>
                <h2 class="text-base font-bold text-slate-900">Undefined</h2>
                <p class="text-slate-500 text-sm mt-0.5">Referenced in code but not created in the database.</p>
            </div>
            {% if undefined_flags is empty %}
                <p class="text-slate-400 text-sm">None.</p>
            {% else %}
                <div class="admin-card overflow-hidden">
                    <table class="admin-table">
                        <tbody>
                            {% for name in undefined_flags %}
                                <tr>
                                    <td class="font-mono text-xs">{{ name }}</td>
                                    <td>
                                        <div class="flex justify-end">
                                            <a href="{{ path('ubermuda_feature_flags_create', {name: name}) }}" class="admin-button-secondary admin-button-small">Create</a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>

        <div class="flex flex-col gap-3">
            <div class="flex items-start justify-between">
                <div>
                    <h2 class="text-base font-bold text-slate-900">Orphaned</h2>
                    <p class="text-slate-500 text-sm mt-0.5">Exist in the database but not referenced in code.</p>
                </div>
                {% if orphan_flags is not empty %}
                    <form method="post" action="{{ path('ubermuda_feature_flags_delete_orphaned') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('feature_flag_delete_orphaned') }}">
                        <button type="submit" class="admin-button-danger admin-button-small">Delete all orphaned</button>
                    </form>
                {% endif %}
            </div>
            {% if orphan_flags is empty %}
                <p class="text-slate-400 text-sm">None.</p>
            {% else %}
                <form method="post" action="{{ path('ubermuda_feature_flags_delete_orphaned') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('feature_flag_delete_orphaned') }}">
                    <div class="admin-card overflow-hidden">
                        <table class="admin-table">
                            <tbody>
                                {% for name in orphan_flags %}
                                    <tr>
                                        <td>
                                            <label class="flex items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="names[]" value="{{ name }}" class="rounded border-slate-300">
                                                <span class="font-mono text-xs">{{ name }}</span>
                                            </label>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div class="flex justify-end mt-3">
                        <button type="submit" class="admin-button-danger admin-button-small">Delete selected</button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
