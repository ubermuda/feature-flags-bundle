<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Feature flags{% endblock %}</title>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block flashes %}
        {% for level, messages in app.flashes %}
            {% for message in messages %}
                <p class="flash flash-{{ level }}" role="status">{{ message|trans }}</p>
            {% endfor %}
        {% endfor %}
    {% endblock %}

    <main>
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
</body>
</html>
